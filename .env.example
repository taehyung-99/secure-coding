# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/local_market_platform?schema=public"

# Used to sign session and CSRF tokens.
# Production requires a strong random value with at least 32 characters.
SESSION_SECRET="replace-with-a-long-random-secret"

# Public application URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Comma-separated origins allowed to open Socket.IO connections.
# Set this to the public HTTPS origin in production.
ALLOWED_ORIGINS="http://localhost:3000"

# Optional: set all three to create the initial admin account with `pnpm prisma:seed`.
# Default categories are created by migrations, not by seed.
# ADMIN_USERNAME=""
# ADMIN_EMAIL=""
# ADMIN_PASSWORD=""
# ADMIN_NICKNAME="관리자"
# ADMIN_REGION="Seoul"
